    {
      "name": "Tickets",
      "item": [
        {
          "name": "Crear ticket",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Ticket creado', function () { pm.response.to.have.status(201); });",
                  "const json = pm.response.json();",
                  "pm.environment.set('ticketId', json.data.id);",
                  "pm.environment.set('assignedAgentId', json.data.assignedAgentId || '');",
                  "console.log('ticketId guardado:', json.data.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "content-type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Error 500 al procesar pago\",\n  \"description\": \"El sistema muestra error 500 cuando intento completar un pago.\",\n  \"category\": \"pagos\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/tickets",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "tickets"]
            }
          },
          "response": []
        },
        {
          "name": "Listar tickets",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/tickets?includeClosed=true",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "tickets"],
              "query": [
                { "key": "includeClosed", "value": "true" }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Obtener ticket por ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/tickets/{{ticketId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "tickets", "{{ticketId}}"]
            }
          },
          "response": []
        },
        {
          "name": "Cambiar estado a IN_PROGRESS",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "content-type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"IN_PROGRESS\",\n  \"reason\": \"El agente inicio la revision del incidente.\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/tickets/{{ticketId}}/status",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "tickets", "{{ticketId}}", "status"]
            }
          },
          "response": []
        },
        {
          "name": "Cambiar estado a RESOLVED",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "content-type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"RESOLVED\",\n  \"reason\": \"Incidente resuelto y validado.\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/tickets/{{ticketId}}/status",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "tickets", "{{ticketId}}", "status"]
            }
          },
          "response": []
        },
        {
          "name": "Reasignar ticket",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "content-type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"assignedAgentId\": \"{{reassignAgentId}}\",\n  \"reason\": \"Redistribucion manual de carga.\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/tickets/{{ticketId}}/assignment",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "tickets", "{{ticketId}}", "assignment"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Comentarios",
      "item": [
        {
          "name": "Agregar comentario publico",
          "request": {
            "method": "POST",
            "header": [
              { "key": "content-type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"Estamos revisando el incidente y te notificaremos avances.\",\n  \"visibility\": \"PUBLIC\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/tickets/{{ticketId}}/comments",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "tickets", "{{ticketId}}", "comments"]
            }
          },
          "response": []
        },
        {
          "name": "Agregar comentario interno",
          "request": {
            "method": "POST",
            "header": [
              { "key": "content-type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"Nota interna: revisar logs de gateway de pagos.\",\n  \"visibility\": \"INTERNAL\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/tickets/{{ticketId}}/comments",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "tickets", "{{ticketId}}", "comments"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Adjuntos",
      "item": [
        {
          "name": "Subir adjunto",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Adjunto procesado', function () { pm.response.to.have.status(201); });",
                  "const json = pm.response.json();",
                  "const lastAttachment = (json.data.attachments || []).slice(-1)[0];",
                  "if (lastAttachment) {",
                  "  pm.environment.set('attachmentId', lastAttachment.id);",
                  "  console.log('attachmentId guardado:', lastAttachment.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "attachments",
                  "type": "file",
                  "src": []
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/tickets/{{ticketId}}/attachments",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "tickets", "{{ticketId}}", "attachments"]
            }
          },
          "response": []
        },
        {
          "name": "Obtener URL de adjunto",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/tickets/{{ticketId}}/attachments/{{attachmentId}}/url",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "tickets", "{{ticketId}}", "attachments", "{{attachmentId}}", "url"]
            }
          },
          "response": []
        },
        {
          "name": "Descargar adjunto autenticado",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/tickets/{{ticketId}}/attachments/{{attachmentId}}/download",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "tickets", "{{ticketId}}", "attachments", "{{attachmentId}}", "download"]
            }
          },
          "response": []
        }
      ]
    },
