                { "key": "ticketId", "value": "{{ticketId}}" }
              ]
            }
          },
          "response": []
        }
      ]
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "authToken", "value": "" },
    { "key": "ticketId", "value": "" },
    { "key": "attachmentId", "value": "" }
  ]
